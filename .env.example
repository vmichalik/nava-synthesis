# Arbiter
ARBITER_URL=http://localhost:8000

# Uniswap
UNISWAP_CHAIN_ID=11155111

# RPC endpoint (defaults to public Sepolia RPC if not set)
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Agent wallet address (used in simulation mode)
AGENT_WALLET=0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18

# Agent private key (set this for LIVE mode - real on-chain execution)
# WARNING: Only use a dedicated testnet wallet. Never use a mainnet wallet with real funds.
# AGENT_PRIVATE_KEY=0x...

# Logging
LOG_DIR=logs
